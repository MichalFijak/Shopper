@page "/edit-item"
@using Shopper.Components.Layout
@using Shopper.Core.Components.Enums
@using Shopper.Services.Components.Dtos
@inject IItemsService itemsService
@inject NavigationManager Navigation

<div class="items-padding">
<ItemForm Title="@itemToModify.Name"
          Model="@newItem"
          CategoryOptions="@CategoryOptions"
          OnSave="SaveItem"
          OnCancel="Cancel" />
</div>
<style>
    .items-padding{
        padding-top:1rem;
    }
</style>

@code {
    private ItemDto newItem = new();
    private ItemDto itemToModify = new();

    private List<(string Value, string Label)> CategoryOptions =
        ItemCategoryExtensions.PolishNames
            .Where(kvp => kvp.Key != ItemCategory.MainList && kvp.Key != ItemCategory.Cart)
            .Select(kvp => (kvp.Key.ToString(), kvp.Value))
            .ToList();

    protected override void OnInitialized()
    {
        itemToModify = itemsService.GetItemToModify() ?? new ItemDto();
        newItem = new ItemDto
        {
            Name = itemToModify.Name,
            Genre = itemToModify.Genre,
            Price = itemToModify.Price,
            Description = itemToModify.Description,
            Amount = itemToModify.Amount
        };
    }

    private void SaveItem()
    {
        if (string.IsNullOrWhiteSpace(newItem.Name)) return; 

        itemsService.ModifyItemAsync(newItem);
        Navigation.NavigateTo("/edit-shopping-list");
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/edit-shopping-list");
    }
}
