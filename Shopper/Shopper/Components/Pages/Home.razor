@page "/"

<h1>@welcomeMessage</h1>

<style>

    h1 {
        font-family: 'Orbitron', sans-serif;
        font-size: 1.25rem;
        color: var(--starlight);
        text-align: center;
        margin: 20px;
    }

    }
</style>


@code {
    private string[] messages = new[]
    {
    "Prawdziwa miłość zaczyna się tam, gdzie kończy się ostatnia kropla ketchupu.",
    "Jeśli naprawdę Ci zależy… dodaj jej ulubioną czekoladę do koszyka.",
    "Romantyzm romantyzmem… ale pustej lodówki nie da się kochać.",
    "Zapomnieć mleka? To już nie błąd — to zdrada.",
    "Czekolada rozwiązuje więcej problemów niż terapia par.",
    "Zakupy we dwoje: ona wybiera, ty nosisz. Idealny balans.",
    "Wchodzisz po jedną rzecz, wychodzisz z chipsami. Klasyk.",
    "Miłość to dzielenie się… nawet ostatnim jogurtem.",
    "Gdy ona mówi ‘kup coś zdrowego’, wszyscy wiemy, że chodzi o sushi.",
    "Telepatia nie działa w sklepie. Lista działa zawsze.",
    "‘Nic nie potrzebuję’ — najniebezpieczniejsze zdanie przed zakupami.",
    "Ty bierzesz koszyk, ona bierze kontrolę. Naturalny porządek wszechświata.",
    "Prawdziwy romans zaczyna się przy półce z przyprawami.",
    "Nikt nie chce wracać po papier toaletowy. Nikt.",
    "Chcesz być bohaterem? Dodaj jej ulubioną herbatę do koszyka.",
    "‘Kup coś lekkiego’ — i tak wrócisz z sernikiem.",
    "Zakupy bez listy to chaos. I dramat. I chipsy.",
    "Oddanie ostatniego jogurtu to najwyższa forma miłości.",
    "Jeśli ona mówi ‘weź coś dobrego’, to znaczy: weź lody. Dużo lodów.",
    "Miłość to patrzenie w gwiazdy… ale wspólne wybieranie sosu do nachosów to dopiero chemia.",
    "Największe ryzyko w związku? Wysłać go po zakupy bez listy.",
    "Kiedy ona mówi ‘ty wybierz’, to test. I wszyscy o tym wiemy.",
    "Prawdziwa para to taka, która potrafi przeżyć zakupy w sobotę o 17.",
    "Miłość jest piękna… ale promocje na czekoladę są piękniejsze.",
    "Jeśli chcesz ją rozśmieszyć — powiedz, że kupiłeś tylko to, po co przyszedłeś."
};

    private string welcomeMessage;

    protected override void OnInitialized()
    {
        var random = new Random();
        welcomeMessage = messages[random.Next(messages.Length)];
    }
}
