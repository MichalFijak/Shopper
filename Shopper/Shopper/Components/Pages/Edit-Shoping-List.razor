@page "/edit-shopping-list"
@using Shopper.Core.Components.Dtos
@using Shopper.Core.Components.Enums
@using Shopper.Services.Components.Dtos
@inject NavigationManager Navigation
@inject IItemsService itemsService
@inject IJSRuntime JS

<div class="edit-navbar">
    <h1>Edycja listy</h1>
</div>

<ul class="item-list">
    @foreach (var entity in items)
    {
        foreach (var item in entity.Items)
        {
            <li id="item-@item.Name" class="item-card">
                <div class="item-content"
                     @ontouchstart="HandleSwipeStart"
                     @ontouchmove="(e) => HandleSwipeMove(e, item)"
                     @ontouchend="(e) => HandleSwipeEnd(e, item)"
                     @onclick="() => NavigateToModifyItem(item)">

                    <h3 class="item-name">@item.Name</h3>

                    @RenderDetail("Rodzaj", GetPolishCategory(item.Genre))
                    @RenderDetail("Cena", item.Price)
                    @RenderDetail("Ilość", item.Amount)
                    @RenderDetail("Opis", item.Description)
                </div>
            </li>
        }
    }
</ul>

<!-- FLOATING BUTTON -->
<button class="fab-add-item" @onclick="NavigateToAddItem">
    <span class="add-item-icon">+</span>
</button>

<style>
    .add-item-icon {
        font-weight: bold;
        color: var(--accent);
    }

    /* NAVBAR */
    .edit-navbar {
        display: flex;
        justify-content: center;
        align-items: center;
        margin: 1rem 0;
        padding: 0 4px;
    }

    /* FLOATING ACTION BUTTON */
    .fab-add-item {
        position: fixed;
        bottom: 22px;
        right: 22px;
        background: linear-gradient(135deg, var(--panel-selected-color), var(--primary-dark));
        color: var(--btn-text);
        width: 48px;
        height: 48px;
        border-radius: 50%;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        cursor: pointer;
        box-shadow: 0 0 22px rgba(var(--accent-rgb), 0.55);
        transition: all 0.25s ease;
        z-index: 999;
    }

        .fab-add-item:hover {
            box-shadow: 0 0 32px rgba(var(--accent-rgb), 0.65);
            transform: translateY(-4px);
        }

        .fab-add-item:active {
            transform: scale(0.94);
            box-shadow: 0 0 18px rgba(var(--accent-rgb), 0.45);
        }

    /* ITEM LIST */
    .item-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .item-card {
        background: var(--panel-color);
        border-radius: 10px;
        margin: 12px 0;
        padding: 14px;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        box-shadow: 0 0 12px rgba(var(--accent-rgb), 0.15);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .item-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 16px rgba(var(--accent-rgb), 0.25);
        }

    .item-content {
        flex: 1;
        cursor: pointer;
    }

    .item-name {
        font-size: 1rem;
        font-weight: bold;
        color: var(--muted);
        margin: 0 0 8px;
        text-shadow: 0 0 6px var(--teal);
    }

    .item-detail {
        margin: 3px 0;
        font-size: 0.8rem;
        color: var(--dark-bronze-text);
    }

        .item-detail span {
            font-weight: 600;
            color: var(--muted);
        }
</style>

@functions {
    RenderFragment? RenderDetail(string label, object value) =>
        string.IsNullOrWhiteSpace(value?.ToString())
            ? null
            : @<p class="item-detail">@label: <span>@value</span></p>;
}

@code {
    private double startX;
    private double currentX;
    private bool isSwiping = false;

    private List<ItemGroupDto> items = new();

    private string GetPolishCategory(string genre)
    {
        if (Enum.TryParse<ItemCategory>(genre, out var category) &&
            ItemCategoryExtensions.PolishNames.TryGetValue(category, out var polish))
        {
            return polish;
        }

        return genre;
    }

    protected override async Task OnInitializedAsync()
    {
        items = await itemsService.RefreshItemsAsync();
        itemsService.OnItemsChanged += HandleItemsChanged;
    }

    private void HandleItemsChanged()
    {
        items = itemsService.GetCachedItems();
        InvokeAsync(StateHasChanged);
    }

    private void NavigateToAddItem()
    {
        Navigation.NavigateTo("/add-item");
    }

    private void NavigateToModifyItem(ItemDto item)
    {
        itemsService.SetItemToModify(item);
        Navigation.NavigateTo("/edit-item");
    }

    private async Task RemoveItem(ItemDto item)
    {
        await itemsService.RemoveItemAsync(item);
    }

    /* SWIPE HANDLERS */

    private void HandleSwipeStart(TouchEventArgs e)
    {
        startX = e.Touches[0].ClientX;
        isSwiping = true;
    }

    private void HandleSwipeMove(TouchEventArgs e, ItemDto item)
    {
        if (!isSwiping) return;

        currentX = e.Touches[0].ClientX;
        var deltaX = currentX - startX;

        var translate = Math.Min(deltaX, 80);

        JS.InvokeVoidAsync("applySwipeTransform", $"item-{item.Name}", translate);
    }

    private async void HandleSwipeEnd(TouchEventArgs e, ItemDto item)
    {
        isSwiping = false;

        var endX = e.ChangedTouches[0].ClientX;
        var deltaX = endX - startX;

        if (deltaX < -50)
        {
            await JS.InvokeVoidAsync("applySwipeRemove", $"item-{item.Name}");
            await RemoveItem(item);
        }
        else
        {
            JS.InvokeVoidAsync("resetSwipeTransform", $"item-{item.Name}");
        }
    }

    public void Dispose()
    {
        itemsService.OnItemsChanged -= HandleItemsChanged;
    }
}
