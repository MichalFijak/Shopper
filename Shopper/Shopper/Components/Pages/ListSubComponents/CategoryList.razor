@using Shopper.Services.Components.Dtos
@inject IJSRuntime JS

<ul class="space-list">
    @if (Items != null && Items.Any())
    {
        @foreach (var item in Items)
        {
            <li class="space-list-item-wrapper">
                <div id="item-@item.Name"
                     class="item-inner @(item.InCart ? "in-cart" : "")"
                     @ontouchstart="HandleSwipeStart"
                     @ontouchmove="(e) => HandleSwipeMove(e, item)"
                     @ontouchend="(e) => HandleSwipeEnd(e, item)">

                    <div class="item-info">
                        <span class="item-name">@item.Name</span>

                        @if (!string.IsNullOrWhiteSpace(item.Genre))
                        {
                            <span class="item-genre">(@item.Genre)</span>
                        }

                        @if (!string.IsNullOrWhiteSpace(item.Description))
                        {
                            <span class="item-description">(@item.Description)</span>
                        }

                        @if (!string.IsNullOrWhiteSpace(item.Price))
                        {
                            <span class="item-price">$ @item.Price</span>
                        }

                        @if (!string.IsNullOrWhiteSpace(item.Amount))
                        {
                            <span class="item-amount">x @item.Amount</span>
                        }
                    </div>

                    <div class="item-actions">
                        @if (item.InCart)
                        {
                            <button class="space-btn move" @onclick="() => MoveItemFromCart.InvokeAsync(item)">
                                Move from cart
                            </button>
                        }
                    </div>
                </div>
            </li>
        }
    }
    else
    {
        <li class="empty-message">No items available</li>
    }
</ul>

<style>
    .space-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        width: 100%;
        overflow-x: hidden;
    }

    .space-list-item-wrapper {
        width: 100%;
        overflow: hidden;
        box-sizing: border-box;
        position: relative;
    }

    .item-inner {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: 1rem;
        border-radius: 14px;
        border: 1px solid var(--panel-rich-color);
        background-color: var(--panel-color);
        box-shadow: 0 0 12px rgba(var(--neon-rgb),1);
        transition: transform 0.18s ease, box-shadow 0.18s ease;
        width: 100%;
        box-sizing: border-box;
    }

        .item-inner.swiping {
            transition: none !important;
        }

        .item-inner:hover {
            transform: translateY(-3px);
            box-shadow: 0 0 16px rgba(var(--neon-rgb),0.25);
        }

        .item-inner.in-cart {
            border-color: rgba(255,180,80,0.6);
            background-color: var(--panel-rich-color);
        }

    .item-info {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        flex: 1;
    }

    .item-name {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--neon);
        text-shadow: 0 0 6px var(--teal);
    }

    .item-genre,
    .item-description,
    .item-price,
    .item-amount {
        font-size: 0.85rem;
        color: var(--muted);
    }

    .item-price,
    .item-amount {
        font-weight: 600;
    }

    .item-actions {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-left: 1rem;
    }

    .space-btn {
        border-radius: 8px;
        font-weight: 600;
        color: var(--light-text);
        border: none;
        padding: var(--btn-padding-vertical) var(--btn-padding-horizontal);
        font-size: var(--btn-font-size-md);
        text-transform: uppercase;
        transition: background 0.2s ease, transform 0.2s ease;
    }

        .space-btn:hover {
            transform: scale(1.05);
        }

        .space-btn.move {
            background: var(--panel-selected-color);
        }

        .space-btn:disabled {
            background: rgba(80,80,120,0.4);
            color: #aaa;
            cursor: not-allowed;
        }

    .empty-message {
        text-align: center;
        color: var(--muted);
        font-style: italic;
        padding: 1rem;
    }
</style>

@code {
    [Parameter] public IEnumerable<ItemDto>? Items { get; set; }

    [Parameter] public EventCallback<ItemDto> SubmitItem { get; set; }
    [Parameter] public EventCallback<ItemDto> MoveItemFromCart { get; set; }
    [Parameter] public EventCallback<ItemDto> RemoveItem { get; set; }

    private double startX;
    private double currentX;
    private bool isSwiping = false;

    private void HandleSwipeStart(TouchEventArgs e)
    {
        startX = e.Touches[0].ClientX;
        isSwiping = true;
    }

    private void HandleSwipeMove(TouchEventArgs e, ItemDto item)
    {
        if (!isSwiping) return;

        currentX = e.Touches[0].ClientX;
        var deltaX = currentX - startX;
        var translate = Math.Min(deltaX, 80);

        if (translate > 0)
        {
            JS.InvokeVoidAsync("applySwipeTransform", $"item-{item.Name}", translate);
        }
        else
        {
            JS.InvokeVoidAsync("applySwipeTransformRed", $"item-{item.Name}", translate);
        }
    }

    private async void HandleSwipeEnd(TouchEventArgs e, ItemDto item)
    {
        isSwiping = false;

        var endX = e.ChangedTouches[0].ClientX;
        var deltaX = endX - startX;

        if (deltaX > 50)
        {
            await JS.InvokeVoidAsync("applySwipeTransform", $"item-{item.Name}");
            await SubmitItem.InvokeAsync(item);

        }
        else if (deltaX < -50)
        {
            await JS.InvokeVoidAsync("applySwipeRemove", $"item-{item.Name}");
            await RemoveItem.InvokeAsync(item);

        }
            JS.InvokeVoidAsync("resetSwipeTransform", $"item-{item.Name}");
    }
}
